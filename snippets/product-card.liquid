{% doc %}
  Renders an interactive product card with color swatches and variant pricing.

  This component supports products whose only variant option is Color. Products
  with additional options, such as Size, require a multi-option variant picker.

  @param {product} product - Product displayed by the card

  @example
  {% render 'product-card', product: product %}
{% enddoc %}

{% liquid
  assign selected_variant = product.selected_or_first_available_variant

  unless selected_variant.available
    assign available_variants = product.variants | where: 'available', true
    assign first_available_variant = available_variants | first

    if first_available_variant != blank
      assign selected_variant = first_available_variant
    endif
  endunless

  assign primary_image = selected_variant.featured_image | default: product.featured_image
%}

<article
  class="flex flex-col gap-3.75 w-fit max-w-92.25"
  data-product-card
  data-product-handle="{{ product.handle }}"
  data-sold-out-text="{{ 'products.product.sold_out' | t | escape }}"
>
  <a
    href="{{ product.url }}?variant={{ selected_variant.id }}"
    class="flex flex-col justify-start align-center"
    data-product-card-link
  >
    <figure class="relative inline-block overflow-hidden rounded-2xl border border-[#e8e8e8] p-5">
      <span
        class="absolute z-[1] top-[20px] left-[20px] py-[6.5px] px-[12.5px] border border-[#ff0000] rounded-[25.61px] bg-transparent text-[#ff0000] text-[15.37px] leading-[17.93px] block"
        data-product-card-sale-badge
        {% unless selected_variant.available and selected_variant.compare_at_price > selected_variant.price %}
          hidden
        {% endunless %}
      >
        {{ 'products.product.on_sale' | t }}
      </span>

      {% if primary_image != blank %}
        <div class="relative h-[301px] w-[275px] shrink-0 overflow-hidden">
          <img
            src="{{ primary_image | image_url: width: 550 }}"
            srcset="{{ primary_image | image_url: width: 275 }} 275w, {{ primary_image | image_url: width: 550 }} 550w"
            sizes="275px"
            alt="{{ primary_image.alt | default: product.title | escape }}"
            class="product-card-image block h-full w-full object-contain transition-opacity duration-300 ease-in-out"
            style="width: 275px; height: 301px; object-fit: contain;"
            loading="lazy"
            width="275"
            height="301"
          >
        </div>
      {% endif %}
    </figure>
  </a>

    <div class="pt-4">
      {% for option in product.options_with_values %}
        {% assign normalized_option_name = option.name | downcase %}

        {% if normalized_option_name == 'color'
          or normalized_option_name == 'colour'
          or normalized_option_name == 'cor'
        %}
          <fieldset class="mt-4 flex gap-2 border-0 p-0">
            <legend class="sr-only">
              {{ option.name }}
            </legend>

            {% for option_value in option.values %}
              {% assign option_handle = option_value.name | handleize %}
              {% assign swatch_background_color = option_value.swatch.color | default: option_handle %}
              {% assign should_check = false %}

              {% if option_value.variant.id == selected_variant.id %}
                {% assign should_check = true %}
              {% endif %}

              {% assign input_id = 'swatch-'
                | append: product.id
                | append: '-'
                | append: option.position
                | append: '-'
                | append: forloop.index
              %}

              <div class="flex gap-3.75 flex-col">
                <input
                  id="{{ input_id }}"
                  class="peer sr-only"
                  type="radio"
                  name="product-card-{{ product.id }}-option-{{ option.position }}"
                  value="{{ option_value.name | escape }}"
                  data-option-position="{{ option.position }}"
                  data-option-value="{{ option_value.name | escape }}"
                  data-variant-id="{{ option_value.variant.id }}"
                  {% if option_value.variant.image != blank %}
                    data-image-url="{{ option_value.variant.image | image_url: width: 550 }}"
                    data-image-srcset="{{ option_value.variant.image | image_url: width: 275 }} 275w, {{ option_value.variant.image | image_url: width: 550 }} 550w"
                  {% endif %}
                  {% if option_value.variant.metafields.custom.secondary_image.value != blank %}
                    data-secondary-image-url="{{ option_value.variant.metafields.custom.secondary_image.value | image_url: width: 550 }}"
                    data-secondary-image-srcset="{{ option_value.variant.metafields.custom.secondary_image.value | image_url: width: 275 }} 275w, {{ option_value.variant.metafields.custom.secondary_image.value | image_url: width: 550 }} 550w"
                  {% endif %}
                  data-price="{{ option_value.variant.price | money | escape }}"
                  data-price-raw="{{ option_value.variant.price }}"
                  data-compare-at-price="{{ option_value.variant.compare_at_price | money | escape }}"
                  data-compare-at-price-raw="{{ option_value.variant.compare_at_price | default: 0 }}"
                  data-available="{{ option_value.variant.available }}"

                  {% if should_check %}
                    checked
                  {% endif %}
                >

                <label
                  for="{{ input_id }}"
                  class="
                    flex h-7 w-7 cursor-pointer items-center justify-center rounded-full
                    border border-transparent p-[3px]
                    transition
                    hover:border-neutral-400
                    peer-checked:border-neutral-900
                    peer-focus-visible:outline
                    peer-focus-visible:outline-2
                    peer-focus-visible:outline-offset-2
                    peer-focus-visible:outline-neutral-900
                  "
                  title="{{ option_value.name | escape }}"
                >
                  <span
                    class="block h-full w-full rounded-full border border-black/10 bg-cover bg-center"
                    data-product-card-swatch
                    data-swatch-color="{{ swatch_background_color | escape }}"
                    {% if option_value.swatch.image %}
                      data-swatch-image="{{ option_value.swatch.image | image_url: width: 80 }}"
                    {% endif %}
                  >
                    <span class="sr-only">
                      {{ option_value.name }}
                    </span>
                  </span>
                </label>
              </div>
            {% endfor %}
          </fieldset>
        {% endif %}
      {% endfor %}

      <div class="pt-4 flex flex-col justify-start gap-1.5">
        <p class="block">{{ product.vendor }}</p>

        <h2 class="font-medium text-[16px] text-[#0A4874]">
          <a href="{{ product.url }}?variant={{ selected_variant.id }}" data-product-card-link>
            {{ product.title }}
          </a>
        </h2>

        <div class="flex gap-2" aria-live="polite" aria-atomic="true">
          <p
            class="line-through weight-regular"
            data-product-card-compare-price
            {% unless selected_variant.available and selected_variant.compare_at_price > selected_variant.price %}
              hidden
            {% endunless %}
          >
            {{ selected_variant.compare_at_price | money }}
          </p>

          <p
            class="text-[#ff0000] weight-regular"
            data-product-card-price
          >
            {% if selected_variant.available %}
              {{ selected_variant.price | money }}
            {% else %}
              {{ 'products.product.sold_out' | t }}
            {% endif %}
          </p>
        </div>
      </div>
    </div>
</article>
