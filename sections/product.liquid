{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign primary_image = current_variant.featured_image | default: product.featured_image
  assign secondary_image = current_variant.metafields.custom.secondary_image.value
%}

<section
  class="flex items-start gap-[clamp(3rem,8vw,8rem)] pt-12 pb-20 font-[family-name:var(--font-primary--family)] max-[749px]:flex-col max-[749px]:gap-10 max-[749px]:pt-8 max-[749px]:pb-12"
  data-product-detail
>
  <div class="flex min-w-0 flex-[1_1_55%] flex-col gap-[60px] max-[749px]:w-full max-[749px]:gap-[30px]">
    <div
      class="w-full max-w-[600px] overflow-hidden rounded-2xl border border-[#e8e8e8] p-5"
      data-product-primary-frame
      {% if primary_image == blank %}hidden{% endif %}
    >
      <img
        class="w-full max-h-[700px] object-contain"
        {% if primary_image != blank %}
          src="{{ primary_image | image_url: width: 900 }}"
        {% endif %}
        alt="{{ primary_image.alt | default: product.title | escape }}"
        width="{{ primary_image.width | default: 900 }}"
        height="{{ primary_image.height | default: 900 }}"
        data-product-primary-image
      >
    </div>

    <div
      class="w-full max-w-[600px] overflow-hidden rounded-2xl border border-[#e8e8e8] p-5"
      data-product-secondary-frame
      {% if secondary_image == blank %}
        hidden
      {% endif %}
    >
      <img
        class="w-full max-h-[700px] object-contain"
        {% if secondary_image != blank %}
          src="{{ secondary_image | image_url: width: 900 }}"
        {% endif %}
        alt="{{ 'products.product.secondary_image_alt' | t: product: product.title | escape }}"
        width="{{ secondary_image.width | default: 900 }}"
        height="{{ secondary_image.height | default: 900 }}"
        loading="lazy"
        data-product-secondary-image
      >
    </div>
  </div>

  <div class="sticky top-8 flex max-w-[480px] flex-[1_1_45%] flex-col gap-4 max-[749px]:static max-[749px]:w-full max-[749px]:max-w-none">
    <p class="text-base">{{ product.vendor }}</p>
    <h1 class="text-[clamp(1.5rem,3vw,2.25rem)] font-medium leading-[1.2] text-[#0a4874]">{{ product.title }}</h1>

    <div class="flex items-center gap-3 text-lg" aria-live="polite">
      <span
        class="text-[#666] line-through"
        data-product-compare-price
        {% unless current_variant.compare_at_price > current_variant.price %}
          hidden
        {% endunless %}
      >
        {{ current_variant.compare_at_price | money }}
      </span>
      <span class="text-[#c00]" data-product-price>
        {{ current_variant.price | money }}
      </span>
    </div>

    {% render 'product-color-swatches', product: product, current_variant: current_variant %}

    <div class="leading-[1.6]">{{ product.description }}</div>

    {% form 'product', product, class: 'mt-2 flex flex-col gap-3' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-variant-id>

      <div class="flex flex-col gap-1.5">
        <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity' | t }}</label>
        <input
          id="Quantity-{{ section.id }}"
          class="min-h-12 w-full border border-[#b8b8b8] bg-white px-4 py-3"
          type="number"
          name="quantity"
          min="1"
          value="1"
        >
      </div>

      <button
        class="min-h-[52px] w-full cursor-pointer rounded-[var(--style-border-radius-inputs)] border border-[#0a4874] bg-[#0a4874] px-6 py-3.5 font-medium text-white transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50"
        type="submit"
        name="add"
        data-product-add-button
        data-add-to-cart-text="{{ 'products.product.add_to_cart' | t | escape }}"
        data-sold-out-text="{{ 'products.product.sold_out' | t | escape }}"
        {% unless current_variant.available %}
          disabled
        {% endunless %}
      >
        {% if current_variant.available %}
          {{ 'products.product.add_to_cart' | t }}
        {% else %}
          {{ 'products.product.sold_out' | t }}
        {% endif %}
      </button>

      <div
        class="[&_.shopify-payment-button]:w-full aria-disabled:cursor-not-allowed aria-disabled:opacity-50"
        data-product-payment-button
        {% unless current_variant.available %}
          inert
          aria-disabled="true"
        {% endunless %}
      >
        {{ form | payment_button }}
      </div>
    {% endform %}
  </div>
</section>

{% render 'product-detail-script' %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
