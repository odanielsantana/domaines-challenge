{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign primary_image = current_variant.featured_image | default: product.featured_image
  assign secondary_image = current_variant.metafields.custom.secondary_image.value
%}

<section class="product-detail" data-product-detail>
  <div class="product-detail__images">
    <div
      class="product-detail__image-frame"
      data-product-primary-frame
      {% if primary_image == blank %}hidden{% endif %}
    >
      <img
        class="product-detail__image"
        {% if primary_image != blank %}
          src="{{ primary_image | image_url: width: 900 }}"
        {% endif %}
        alt="{{ primary_image.alt | default: product.title | escape }}"
        width="{{ primary_image.width | default: 900 }}"
        height="{{ primary_image.height | default: 900 }}"
        data-product-primary-image
      >
    </div>

    <div
      class="product-detail__image-frame"
      data-product-secondary-frame
      {% if secondary_image == blank %}
        hidden
      {% endif %}
    >
      <img
        class="product-detail__image"
        {% if secondary_image != blank %}
          src="{{ secondary_image | image_url: width: 900 }}"
        {% endif %}
        alt="{{ 'products.product.secondary_image_alt' | t: product: product.title | escape }}"
        width="{{ secondary_image.width | default: 900 }}"
        height="{{ secondary_image.height | default: 900 }}"
        loading="lazy"
        data-product-secondary-image
      >
    </div>
  </div>

  <div class="product-detail__content">
    <p class="product-detail__vendor">{{ product.vendor }}</p>
    <h1 class="product-detail__title">{{ product.title }}</h1>

    <div class="product-detail__prices" aria-live="polite">
      <span
        class="product-detail__compare-price"
        data-product-compare-price
        {% unless current_variant.compare_at_price > current_variant.price %}
          hidden
        {% endunless %}
      >
        {{ current_variant.compare_at_price | money }}
      </span>
      <span class="product-detail__price" data-product-price>
        {{ current_variant.price | money }}
      </span>
    </div>

    {% render 'product-color-swatches', product: product, current_variant: current_variant %}

    <div class="product-detail__description">{{ product.description }}</div>

    {% form 'product', product, class: 'product-detail__form' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-variant-id>

      <div class="product-detail__quantity">
        <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity' | t }}</label>
        <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">
      </div>

      <button
        class="product-detail__add-button"
        type="submit"
        name="add"
        data-product-add-button
        data-add-to-cart-text="{{ 'products.product.add_to_cart' | t | escape }}"
        data-sold-out-text="{{ 'products.product.sold_out' | t | escape }}"
        {% unless current_variant.available %}
          disabled
        {% endunless %}
      >
        {% if current_variant.available %}
          {{ 'products.product.add_to_cart' | t }}
        {% else %}
          {{ 'products.product.sold_out' | t }}
        {% endif %}
      </button>

      <div
        class="product-detail__payment-button"
        data-product-payment-button
        {% unless current_variant.available %}
          inert
          aria-disabled="true"
        {% endunless %}
      >
        {{ form | payment_button }}
      </div>
    {% endform %}
  </div>
</section>

{% stylesheet %}
  .product-detail {
    display: flex;
    align-items: flex-start;
    gap: clamp(3rem, 8vw, 8rem);
    padding-block: 3rem 5rem;
    font-family: var(--font-primary--family);
  }

  .product-detail__images {
    display: flex;
    flex: 1 1 55%;
    flex-direction: column;
    gap: 60px;
    min-width: 0;
  }

  .product-detail__image-frame {
    width: 100%;
    max-width: 600px;
    overflow: hidden;
    border: 1px solid #e8e8e8;
    border-radius: 16px;
    padding: 20px;
  }

  .product-detail__image-frame[hidden] {
    display: none;
  }

  .product-detail__image {
    width: 100%;
    max-height: 700px;
    object-fit: contain;
  }

  .product-detail__content {
    position: sticky;
    top: 2rem;
    display: flex;
    flex: 1 1 45%;
    flex-direction: column;
    gap: 1rem;
    max-width: 480px;
  }

  .product-detail__vendor {
    font-size: 1rem;
  }

  .product-detail__title {
    color: #0a4874;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 500;
    line-height: 1.2;
  }

  .product-detail__prices {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.125rem;
  }

  .product-detail__compare-price {
    color: #666;
    text-decoration: line-through;
  }

  .product-detail__compare-price[hidden] {
    display: none;
  }

  .product-detail__price {
    color: #ff0000;
  }

  .product-detail__colors {
    margin-top: 0.5rem;
    padding: 0;
    border: 0;
  }

  .product-detail__colors legend {
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .product-detail__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .product-detail__swatch input,
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .product-detail__swatch label {
    display: flex;
    width: 28px;
    height: 28px;
    padding: 3px;
    cursor: pointer;
    border: 1px solid transparent;
    border-radius: 50%;
    transition: border-color 150ms ease;
  }

  .product-detail__swatch label:hover {
    border-color: #a3a3a3;
  }

  .product-detail__swatch input:checked + label {
    border-color: #171717;
  }

  .product-detail__swatch input:focus-visible + label {
    outline: 2px solid #171717;
    outline-offset: 2px;
  }

  .product-detail__swatch-color {
    width: 100%;
    height: 100%;
    border: 1px solid rgb(0 0 0 / 10%);
    border-radius: 50%;
    background-position: center;
    background-size: cover;
  }

  .product-detail__description {
    line-height: 1.6;
  }

  .product-detail__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .product-detail__quantity {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .product-detail__quantity input {
    width: 100%;
    min-height: 48px;
    padding: 0.75rem 1rem;
    border: 1px solid #b8b8b8;
    background: #fff;
  }

  .product-detail__add-button {
    width: 100%;
    min-height: 52px;
    padding: 0.875rem 1.5rem;
    cursor: pointer;
    border: 1px solid #0a4874;
    border-radius: var(--style-border-radius-inputs);
    background: #0a4874;
    color: #fff;
    font-weight: 500;
    transition: opacity 150ms ease;
  }

  .product-detail__add-button:hover:not(:disabled) {
    opacity: 0.88;
  }

  .product-detail__add-button:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .product-detail__payment-button .shopify-payment-button {
    width: 100%;
  }

  .product-detail__payment-button[aria-disabled='true'] {
    cursor: not-allowed;
    opacity: 0.5;
  }

  @media (max-width: 749px) {
    .product-detail {
      flex-direction: column;
      gap: 2.5rem;
      padding-block: 2rem 3rem;
    }

    .product-detail__images,
    .product-detail__content {
      width: 100%;
      max-width: none;
    }

    .product-detail__images {
      gap: 30px;
    }

    .product-detail__content {
      position: static;
    }
  }
{% endstylesheet %}

{% render 'product-detail-script' %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
